<data name="Control_Display_Name_Key" xml:space="preserve">
    <value>Entiteitselectie</value>
</data>
<data name="Control_Description_Key" xml:space="preserve">
    <value>Een doorzoekbare keuzelijst die alle beschikbare Dataverse-entiteiten toont en de gebruiker in staat stelt er één te selecteren. De logische naam van de geselecteerde entiteit wordt opgeslagen in het gebonden veld. Sorteervolgorde (op weergavenaam of objecttypecode) en optielabelindeling (alleen weergavenaam, of weergavenaam met schemanaam) zijn instelbaar.</value>
</data>
<data name="Property_Display_Key" xml:space="preserve">
    <value>Logische entiteitsnaam</value>
</data>
<data name="Property_Desc_Key" xml:space="preserve">
    <value>De logische naam van de geselecteerde Dataverse-entiteit. Wordt bij het laden vooringevuld vanuit het gebonden veld en bijgewerkt wanneer de gebruiker een nieuwe selectie maakt.</value>
</data>
<data name="sortTypeProperty_Display_Key" xml:space="preserve">
    <value>Sorteervolgorde</value>
</data>
<data name="sortTypeProperty_Desc_Key" xml:space="preserve">
    <value>Bepaalt de volgorde waarin entiteiten in de keuzelijst worden weergegeven.</value>
</data>
<data name="sortType_orderByName_Display_Key" xml:space="preserve">
    <value>Op weergavenaam</value>
</data>
<data name="sortType_orderByName_Desc_Key" xml:space="preserve">
    <value>Entiteiten worden alfabetisch gesorteerd op weergavenaam.</value>
</data>
<data name="sortType_orderByObjectTypeCode_Display_Key" xml:space="preserve">
    <value>Op objecttypecode</value>
</data>
<data name="sortType_orderByObjectTypeCode_Desc_Key" xml:space="preserve">
    <value>Entiteiten worden numeriek gesorteerd op objecttypecode.</value>
</data>
<data name="entitySelectorOptionDisplayModeProperty_Display_Key" xml:space="preserve">
    <value>Optielabelindeling</value>
</data>
<data name="entitySelectorOptionDisplayModeProperty_Desc_Key" xml:space="preserve">
    <value>Bepaalt hoe elke entiteit wordt gelabeld in de keuzelijst.</value>
</data>
<data name="entityNameOnly_Display_Key" xml:space="preserve">
    <value>Alleen weergavenaam</value>
</data>
<data name="entityNameOnly_Desc_Key" xml:space="preserve">
    <value>Elke optie toont alleen de weergavenaam van de entiteit (bijv. 'Account').</value>
</data>
<data name="entityNameAndSchemaName_Display_Key" xml:space="preserve">
