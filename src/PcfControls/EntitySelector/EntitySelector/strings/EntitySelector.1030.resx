<data name="Control_Display_Name_Key" xml:space="preserve">
    <value>Entitetsvælger</value>
</data>
<data name="Control_Description_Key" xml:space="preserve">
    <value>En søgbar kombinationsboks, der viser alle tilgængelige Dataverse-entiteter, og lader brugeren vælge en. Det logiske navn på den valgte entitet skrives til det bundne felt. Sorteringsrækkefølge (efter visningsnavn eller objekttypekode) og valgetiketformat (kun visningsnavn eller visningsnavn med skemanavn) kan konfigureres.</value>
</data>
<data name="Property_Display_Key" xml:space="preserve">
    <value>Logisk entitetsnavn</value>
</data>
<data name="Property_Desc_Key" xml:space="preserve">
    <value>Det logiske navn på den valgte Dataverse-entitet. Forudfyldes ved indlæsning fra den bundne feltværdi og opdateres, når brugeren foretager et nyt valg.</value>
</data>
<data name="sortTypeProperty_Display_Key" xml:space="preserve">
    <value>Sorteringsrækkefølge</value>
</data>
<data name="sortTypeProperty_Desc_Key" xml:space="preserve">
    <value>Styrer den rækkefølge, entiteterne vises i rullelisten.</value>
</data>
<data name="sortType_orderByName_Display_Key" xml:space="preserve">
    <value>Efter visningsnavn</value>
</data>
<data name="sortType_orderByName_Desc_Key" xml:space="preserve">
    <value>Entiteter sorteres alfabetisk efter deres visningsnavn.</value>
</data>
<data name="sortType_orderByObjectTypeCode_Display_Key" xml:space="preserve">
    <value>Efter objekttypekode</value>
</data>
<data name="sortType_orderByObjectTypeCode_Desc_Key" xml:space="preserve">
    <value>Entiteter sorteres numerisk efter deres objekttypekode.</value>
</data>
<data name="entitySelectorOptionDisplayModeProperty_Display_Key" xml:space="preserve">
    <value>Format for valgetiket</value>
</data>
<data name="entitySelectorOptionDisplayModeProperty_Desc_Key" xml:space="preserve">
    <value>Styrer, hvordan hver entitet vises i rullelisten.</value>
</data>
<data name="entityNameOnly_Display_Key" xml:space="preserve">
