<data name="Control_Display_Name_Key" xml:space="preserve">
    <value>Entitásválasztó</value>
</data>
<data name="Control_Description_Key" xml:space="preserve">
    <value>Kereshető legördülő mező, amely felsorolja az összes elérhető Dataverse-entitást, és lehetővé teszi a felhasználó számára, hogy kiválasszon egyet. A kiválasztott entitás logikai neve a kötött mezőbe kerül írásra. A rendezési sorrend (megjelenítési név vagy objektumtípus-kód szerint) és az opciócímke formátuma (csak megjelenítési név, vagy megjelenítési név sématnévvel) konfigurálható.</value>
</data>
<data name="Property_Display_Key" xml:space="preserve">
    <value>Entitás logikai neve</value>
</data>
<data name="Property_Desc_Key" xml:space="preserve">
    <value>A kiválasztott Dataverse-entitás logikai neve. Betöltéskor a kötött mező értékéből előre kitöltődik, és frissül minden alkalommal, amikor a felhasználó új kiválasztást végez.</value>
</data>
<data name="sortTypeProperty_Display_Key" xml:space="preserve">
    <value>Rendezési sorrend</value>
</data>
<data name="sortTypeProperty_Desc_Key" xml:space="preserve">
    <value>Meghatározza, hogy az entitások milyen sorrendben jelennek meg a legördülő listában.</value>
</data>
<data name="sortType_orderByName_Display_Key" xml:space="preserve">
    <value>Megjelenítési név szerint</value>
</data>
<data name="sortType_orderByName_Desc_Key" xml:space="preserve">
    <value>Az entitások betűrendben, megjelenítési nevük szerint vannak rendezve.</value>
</data>
<data name="sortType_orderByObjectTypeCode_Display_Key" xml:space="preserve">
    <value>Objektumtípus-kód szerint</value>
</data>
<data name="sortType_orderByObjectTypeCode_Desc_Key" xml:space="preserve">
    <value>Az entitások számszerűen, objektumtípus-kódjuk szerint vannak rendezve.</value>
</data>
<data name="entitySelectorOptionDisplayModeProperty_Display_Key" xml:space="preserve">
    <value>Opciócímke formátuma</value>
</data>
<data name="entitySelectorOptionDisplayModeProperty_Desc_Key" xml:space="preserve">
