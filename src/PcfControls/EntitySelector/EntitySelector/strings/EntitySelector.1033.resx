<data name="Control_Display_Name_Key" xml:space="preserve">
    <value>Entity Selector</value>
</data>
<data name="Control_Description_Key" xml:space="preserve">
    <value>A searchable combobox that lists all available Dataverse entities and lets the user pick one. The logical name of the selected entity is written to the bound field. Sort order (by display name or object type code) and option label format (display name only, or display name with schema name) are configurable.</value>
</data>
<data name="Property_Display_Key" xml:space="preserve">
    <value>Entity Logical Name</value>
</data>
<data name="Property_Desc_Key" xml:space="preserve">
    <value>The logical name of the selected Dataverse entity. Pre-populated on load from the bound field value; updated whenever the user makes a new selection.</value>
</data>
<data name="sortTypeProperty_Display_Key" xml:space="preserve">
    <value>Sort Order</value>
</data>
<data name="sortTypeProperty_Desc_Key" xml:space="preserve">
    <value>Controls the order in which entities are listed in the dropdown.</value>
</data>
<data name="sortType_orderByName_Display_Key" xml:space="preserve">
    <value>By Display Name</value>
</data>
<data name="sortType_orderByName_Desc_Key" xml:space="preserve">
    <value>Entities are sorted alphabetically by their display name.</value>
</data>
<data name="sortType_orderByObjectTypeCode_Display_Key" xml:space="preserve">
    <value>By Object Type Code</value>
</data>
<data name="sortType_orderByObjectTypeCode_Desc_Key" xml:space="preserve">
    <value>Entities are sorted numerically by their object type code.</value>
</data>
<data name="entitySelectorOptionDisplayModeProperty_Display_Key" xml:space="preserve">
    <value>Option Label Format</value>
</data>
<data name="entitySelectorOptionDisplayModeProperty_Desc_Key" xml:space="preserve">
    <value>Controls how each entity is labelled in the dropdown list.</value>
</data>
<data name="entityNameOnly_Display_Key" xml:space="preserve">
    <value>Display Name Only</value>
</data>
<data name="entityNameOnly_Desc_Key" xml:space="preserve">
    <value>Each option shows the entity display name only (e.g. "Account").</value>
</data>
<data name="entityNameAndSchemaName_Display_Key" xml:space="preserve">
    <value>Display Name and Schema Name</value>
</data>
<data name="entityNameAndSchemaName_Desc_Key" xml:space="preserve">
    <value>Each option shows the entity display name followed by its logical name (e.g. "Account - account").</value>
</data>
