<data name="Control_Display_Name_Key" xml:space="preserve">
    <value>Entitätsauswahl</value>
</data>
<data name="Control_Description_Key" xml:space="preserve">
    <value>Ein durchsuchbares Kombinationsfeld, das alle verfügbaren Dataverse-Entitäten auflistet und dem Benutzer die Auswahl einer Entität ermöglicht. Der logische Name der ausgewählten Entität wird in das gebundene Feld geschrieben. Sortierreihenfolge (nach Anzeigename oder Objekttypcode) und Optionsbeschriftung (nur Anzeigename oder Anzeigename mit Schemaname) sind konfigurierbar.</value>
</data>
<data name="Property_Display_Key" xml:space="preserve">
    <value>Logischer Entitätsname</value>
</data>
<data name="Property_Desc_Key" xml:space="preserve">
    <value>Der logische Name der ausgewählten Dataverse-Entität. Wird beim Laden aus dem gebundenen Feld vorbelegt und aktualisiert, wenn der Benutzer eine neue Auswahl trifft.</value>
</data>
<data name="sortTypeProperty_Display_Key" xml:space="preserve">
    <value>Sortierreihenfolge</value>
</data>
<data name="sortTypeProperty_Desc_Key" xml:space="preserve">
    <value>Legt fest, in welcher Reihenfolge die Entitäten in der Dropdown-Liste angezeigt werden.</value>
</data>
<data name="sortType_orderByName_Display_Key" xml:space="preserve">
    <value>Nach Anzeigename</value>
</data>
<data name="sortType_orderByName_Desc_Key" xml:space="preserve">
    <value>Entitäten werden alphabetisch nach ihrem Anzeigenamen sortiert.</value>
</data>
<data name="sortType_orderByObjectTypeCode_Display_Key" xml:space="preserve">
    <value>Nach Objekttypcode</value>
</data>
<data name="sortType_orderByObjectTypeCode_Desc_Key" xml:space="preserve">
    <value>Entitäten werden numerisch nach ihrem Objekttypcode sortiert.</value>
</data>
<data name="entitySelectorOptionDisplayModeProperty_Display_Key" xml:space="preserve">
    <value>Optionsbeschriftungsformat</value>
</data>
<data name="entitySelectorOptionDisplayModeProperty_Desc_Key" xml:space="preserve">
    <value>Legt fest, wie jede Entität in der Dropdown-Liste beschriftet wird.</value>
</data>
<data name="entityNameOnly_Display_Key" xml:space="preserve">
    <value>Nur Anzeigename</value>
</data>
<data name="entityNameOnly_Desc_Key" xml:space="preserve">
    <value>Jede Option zeigt nur den Anzeigenamen der Entität (z. B. „Firma").</value>
</data>
<data name="entityNameAndSchemaName_Display_Key" xml:space="preserve">
    <value>Anzeigename und Schemaname</value>
</data>
<data name="entityNameAndSchemaName_Desc_Key" xml:space="preserve">
    <value>Jede Option zeigt den Anzeigenamen gefolgt vom logischen Namen (z. B. „Firma – account").</value>
</data>
<data name="Placeholder_Key" xml:space="preserve">
